{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "fable",
  "effortLevel": "xhigh",
  "permissions": {
    "defaultMode": "default",
    "ask": [
      "Bash(git push)",
      "Bash(git push *)",
      "Bash(higgsfield generate create *)",
      "Bash(higgsfield generate workflow *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/guard-protected-input.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/check-touched-frontend.sh",
            "timeout": 45
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/final-cinematic-gate.sh",
            "timeout": 20
          }
        ]
      }
    ]
  }
}
