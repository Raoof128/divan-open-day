{
  "name": "divan-open-day",
  "version": "0.1.0",
  "description": "Work-in-progress source for the DIVAN Persian poetry Open Day experience.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Raoof128/divan-open-day.git"
  },
  "homepage": "https://github.com/Raoof128/divan-open-day#readme",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.13.0 <23",
    "pnpm": "10.33.0"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "pnpm build:fixture",
    "build:fixture": "tsx scripts/build.ts --profile fixture",
    "build:production": "tsx scripts/build.ts --profile production",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "bash scripts/check.sh",
    "typecheck": "tsc --noEmit --pretty false",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:components": "vitest run tests/components",
    "test:content": "vitest run tests/content",
    "test:a11y": "vitest run tests/accessibility",
    "test:offline": "vitest run tests/offline",
    "test:share": "vitest run tests/share",
    "test:visual": "playwright test tests/e2e/visual.spec.ts",
    "test:e2e": "playwright test",
    "test:security": "vitest run tests/security",
    "test:performance": "vitest run tests/performance",
    "verify:dist": "tsx scripts/verify-dist.ts && tsx scripts/poetry/inspect-public-bundle.ts",
    "verify:privacy": "tsx scripts/verify-privacy.ts",
    "verify:container": "tsx scripts/ops/verify-container.ts",
    "verify:headers": "tsx scripts/ops/verify-headers.ts",
    "verify:origin-isolation": "tsx scripts/ops/verify-origin-isolation.ts",
    "verify:rollback": "tsx scripts/ops/verify-rollback.ts",
    "verify:qr": "tsx scripts/qr/verify-qr.ts",
    "poetry:fetch": "tsx scripts/poetry/fetch-sources.ts",
    "poetry:verify-sources": "tsx scripts/poetry/verify-source-lock.ts",
    "poetry:extract": "tsx scripts/poetry/extract-sources.ts",
    "poetry:extract-bell": "tsx scripts/poetry/extract-hafez-bell.ts",
    "poetry:build-candidates": "tsx scripts/poetry/build-candidate-index.ts",
    "poetry:inventory": "tsx scripts/poetry/build-corpus-inventory.ts",
    "poetry:fetch-masnavi": "tsx scripts/poetry/fetch-masnavi-sections.ts",
    "poetry:build-production": "tsx scripts/poetry/build-production-corpus.ts"
  },
  "dependencies": {
    "@fontsource/cormorant-garamond": "5.2.11",
    "@fontsource/inter": "5.2.8",
    "@fontsource/noto-nastaliq-urdu": "5.2.8",
    "@fontsource/vazirmatn": "5.2.8",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "22.20.1",
    "@types/pdfkit": "0.17.6",
    "@types/qrcode": "1.5.6",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "axe-core": "4.12.1",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "fast-glob": "3.3.3",
    "jsdom": "29.1.1",
    "pdfkit": "0.19.1",
    "prettier": "3.9.5",
    "qrcode": "1.5.4",
    "sharp": "0.35.3",
    "svgo": "4.0.2",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "yaml": "2.9.0"
  }
}
