{
	admin off
	auto_https off
	log {
		output stderr
		level ERROR
	}
}

:8080 {
	root * /srv

	# Access logs are deliberately disabled: origin errors contain no visitor data.
	log {
		output discard
	}

	header {
		Content-Security-Policy "default-src 'none'; base-uri 'none'; frame-ancestors 'none'; form-action 'none'; script-src 'self'; style-src 'self'; font-src 'self'; img-src 'self' data: blob:; media-src 'self'; connect-src 'self'; worker-src 'self'; manifest-src 'self'; object-src 'none';"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
		Cross-Origin-Opener-Policy "same-origin"
		Cross-Origin-Resource-Policy "same-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), accelerometer=(), gyroscope=(), magnetometer=(), payment=(), usb=()"
		# Unknown, missing, and unhashed paths fail closed. More specific
		# existing-file matchers below replace this default.
		?Cache-Control "no-store"
		-Server
	}

	# `path_regexp`, not `path`: Caddy's `path` matcher is case-insensitive, but
	# the tunnel denies this route with a case-sensitive Go regexp (`^/healthz$`).
	# `/HEALTHZ` therefore misses the tunnel's deny rule and reaches the origin,
	# which would answer it "ok" — defeating the design authority's requirement
	# that public /healthz return 404. Both layers must be case-exact.
	@health path_regexp health ^/healthz$
	handle @health {
		header Cache-Control "no-store"
		respond "ok" 200
	}

	@immutable {
		path_regexp immutable ^(?:/(?:content|assets)/[a-f0-9]{64}\.json|/assets/[A-Za-z0-9][A-Za-z0-9._-]*-[a-f0-9]{16}\.(?:css|js|woff2|avif|png|svg|webp)|/audio/(?:[A-Za-z0-9_-][A-Za-z0-9._-]*/)*(?:[a-f0-9]{8}[A-Za-z0-9._-]*|[A-Za-z0-9_-][A-Za-z0-9._-]*[a-f0-9]{8}[A-Za-z0-9._-]*)\.(?:mp3|ogg)|/fonts/(?:[A-Za-z0-9_-][A-Za-z0-9._-]*/)*(?:[a-f0-9]{8}[A-Za-z0-9._-]*|[A-Za-z0-9_-][A-Za-z0-9._-]*[a-f0-9]{8}[A-Za-z0-9._-]*)\.woff2|/icons/(?:[A-Za-z0-9_-][A-Za-z0-9._-]*/)*(?:[a-f0-9]{8}[A-Za-z0-9._-]*|[A-Za-z0-9_-][A-Za-z0-9._-]*[a-f0-9]{8}[A-Za-z0-9._-]*)\.svg|/images/(?:[A-Za-z0-9_-][A-Za-z0-9._-]*/)*(?:[a-f0-9]{8}[A-Za-z0-9._-]*|[A-Za-z0-9_-][A-Za-z0-9._-]*[a-f0-9]{8}[A-Za-z0-9._-]*)\.(?:avif|webp|png))$
		file
	}
	# `no-transform` belongs here most of all: this matcher carries the
	# content-addressed corpus and every hashed asset — the exact bytes the
	# service worker verifies by SHA-256 before staging a release. `immutable`
	# (RFC 8246) only tells clients not to revalidate; it does not forbid an
	# intermediary from rewriting content. Only RFC 9111 `no-transform` does.
	header @immutable Cache-Control "public, max-age=31536000, immutable, no-transform"

	@manifest {
		path /manifest.webmanifest
		file
	}
	header @manifest Cache-Control "public, max-age=3600"

	@noCacheFiles {
		path /release.json /service-worker.js /offline.html
		file
	}
	header @noCacheFiles Cache-Control "no-cache, must-revalidate, no-transform"

	@technical path /content/* /release.json /service-worker.js /offline /offline.html
	header @technical X-Robots-Tag "noindex"

	# Missing static and data paths remain 404 and never receive the SPA shell.
	@staticAssets path /content/* /assets/* /audio/* /fonts/* /images/* /icons/* /manifest.webmanifest /release.json /service-worker.js /offline.html /favicon.ico /mask-icon.svg
	handle @staticAssets {
		route {
			file_server {
				pass_thru
			}
			header Cache-Control "no-store"
			respond "404 Not Found" 404
		}
	}

	# `no-transform` is load-bearing, not decorative. Cloudflare Web Analytics
	# auto-injection rewrites HTML in flight for real user agents only, which
	# pushes the shell past the byte ceiling the service worker verifies it
	# against and takes every controlled client offline. RFC 9111 no-transform
	# forbids that rewrite at every intermediary, and Cloudflare honours it.
	# The release is content-addressed: proxy-injected bytes are never correct.
	@documents path / /index.html /about /credits /accessibility /privacy /offline
	header @documents Cache-Control "no-cache, must-revalidate, no-transform"
	handle @documents {
		rewrite * /index.html
		file_server
	}

	# Serve other exact files only; directory browsing and broad SPA fallback stay off.
	handle {
		route {
			file_server {
				pass_thru
			}
			header Cache-Control "no-store"
			respond "404 Not Found" 404
		}
	}
}
