{
	admin off
	auto_https off
	log {
		output stderr
		level ERROR
	}
}

:8080 {
	root * /srv

	# Access logs are deliberately disabled: origin errors contain no visitor data.
	log {
		output discard
	}

	header {
		Content-Security-Policy "default-src 'none'; base-uri 'none'; frame-ancestors 'none'; form-action 'none'; script-src 'self'; style-src 'self'; font-src 'self'; img-src 'self' data: blob:; media-src 'self'; connect-src 'self'; worker-src 'self'; manifest-src 'self'; object-src 'none';"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
		Cross-Origin-Opener-Policy "same-origin"
		Cross-Origin-Resource-Policy "same-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), accelerometer=(), gyroscope=(), magnetometer=(), payment=(), usb=()"
		?Cache-Control "no-cache, must-revalidate"
		-Server
	}

	@health path /healthz
	handle @health {
		header Cache-Control "no-store"
		respond "ok" 200
	}

	@immutable path /content/* /assets/* /audio/* /fonts/* /images/* /icons/*
	header @immutable Cache-Control "public, max-age=31536000, immutable"

	@manifest path /manifest.webmanifest
	header @manifest Cache-Control "public, max-age=3600"

	@technical path /content/* /release.json /service-worker.js /offline
	header @technical X-Robots-Tag "noindex"

	# Missing static and data paths remain 404 and never receive the SPA shell.
	@staticAssets path /content/* /assets/* /audio/* /fonts/* /images/* /icons/* /manifest.webmanifest /release.json /service-worker.js /favicon.ico /mask-icon.svg
	handle @staticAssets {
		file_server
	}

	@documents path / /about /credits /accessibility /privacy /offline
	handle @documents {
		rewrite * /index.html
		file_server
	}

	# Serve other exact files only; directory browsing and broad SPA fallback stay off.
	handle {
		file_server
	}
}
