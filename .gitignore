.env
.env.*
!.env.example
.worktrees/
.superpowers/
.divan-build.lock
.divan-*-stage-*
.divan-dist-backup-*
.pnpm-store/
.tmp-tests/
node_modules/
dist/
content-private/*
!content-private/README.md
# Raw archival source books are never committed to ordinary Git (large, and kept
# out of public history). Manifests, hashes and reports under sources-private/
# ARE committed; only raw/ and extracted staging are ignored.
sources-private/poetry/raw/**
!sources-private/poetry/raw/.gitkeep
sources-private/poetry/extracted/**
!sources-private/poetry/extracted/.gitkeep
# Bell OCR reconstruction: rendered page images and per-page OCR text are a
# derivative of the whole scanned book. Never commit them.
sources-private/poetry/bell-ocr/**
# Candidate reports carry verse excerpts — keep them out of Git; the text-free
# candidates-summary.json is committed instead.
sources-private/poetry/reports/*-candidates.json
ops/cloudflared/*.json
ops/cloudflared/config.yml
coverage/
playwright-report/
test-results/
*.log
.DS_Store
*.tsbuildinfo
docs/evidence/runtime/

# Local Claude Code working guidance; not shared project state (see CLAUDE.md line 3).
CLAUDE.md
